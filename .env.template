# .env.template - Plantilla NO debe subirse al repo con valores reales
# Copiar a `.env` en el servidor de despliegue y completar los valores

# Database connection (ejemplo para SQL Server / PostgreSQL según tu provider)
ConnectionStrings__Default=Data Source=SERVER_OR_PATH;Initial Catalog=thtracker;User ID=USER;Password=PASSWORD

# Seed admin (copiado desde appsettings.json)
Seed__DefaultAdminEmail=admin@thtracker.local
Seed__DefaultAdminPassword=contraseña1234@
Seed__DefaultAdminName=Administrator

# JWT
Jwt__SecretKey=UnaClaveLargaYSeguraReemplazar
Jwt__Issuer=https://tu-dominio.com
Jwt__Audience=https://tu-dominio.com
Jwt__AccessTokenExpirationMinutes=60
Jwt__RefreshTokenExpirationDays=7

# Otros
AllowedHosts=*
ASPNETCORE_ENVIRONMENT=Production

# CORS - Orígenes permitidos (separados por comas)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Opcional: OWNER usado por docker-compose (reemplace si usa GHCR)
OWNER=REPLACE_OWNER
